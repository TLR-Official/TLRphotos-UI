dist/
dist-ssr/

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# PocketBase (后端相关，不上传到前端仓库)
# 如果前端仓库不需要 PocketBase 相关文件，可以排除
# pb_data/
# pb_migrations/
# pocketbase*

# Thumbnails cache (缩略图缓存)
.thumbnails/

# Local uploads (用户上传的图片)
uploads/

# Nginx SSL certificates (SSL证书，不上传)
nginx.conf
/etc/nginx/sites-available/tlrphotos
/etc/letsencrypt/
/root/.cloudflare.ini

# Cloudflare credentials
*.cloudflare.ini

# Systemd service files
*.service

# Local sync scripts
sync.sh

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
.cache/

# Backend database
backend/data/*.db
backend/data/*.log
backend/data/*
!backend/data/.gitkeep

# Uploads directory
backend/uploads/

# Trae AI history
.history/

# SSH keys (private/public keys should never be committed)
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.key
*.pem
